# WattsHub — Firebase Environment Variables Template
# ────────────────────────────────────────────────────
# This file IS committed to git as a reference.
# To use: copy to .env.local and fill in real values.
#
# For Netlify deployment, add each variable in:
#   Netlify Dashboard → Site → Environment variables

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
