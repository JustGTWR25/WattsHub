{
  "rules": {
    "wh": {
      "allowedUids": {
        ".read": "auth != null && root.child('wh/allowedUids').child(auth.uid).exists()",
        ".write": "auth != null && root.child('wh/allowedUids').child(auth.uid).child('role').val() === 'admin'"
      },
      "pendingAccess": {
        ".read": "auth != null && root.child('wh/allowedUids').child(auth.uid).child('role').val() === 'admin'",
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && (auth.uid === $uid || root.child('wh/allowedUids').child(auth.uid).child('role').val() === 'admin')",
          ".validate": "newData.hasChildren(['requestedAt']) && newData.child('requestedAt').isNumber()"
        }
      },
      "$section": {
        ".read": "auth != null && root.child('wh/allowedUids').child(auth.uid).exists()",
        ".write": "auth != null && root.child('wh/allowedUids').child(auth.uid).exists()"
      }
    }
  }
}
